# Copy to .env and fill in:  cp .env.example .env
# .env is gitignored — never commit your real token.
# mlxctl loads .env automatically (via python-dotenv) at startup.

# Hugging Face access token. Raises download rate limits (no more throttling on
# `mlxctl pull`) and unlocks gated/private repos. A "read" scope is enough.
# Create one at: https://huggingface.co/settings/tokens
HF_TOKEN=

# ---------------------------------------------------------------------------
# Optional settings. Each maps to a hard default; uncomment only to override.
# Precedence: built-in default < this .env < shell env < explicit CLI flag.
# ---------------------------------------------------------------------------

# Default model nickname (or full HF repo id) used by `serve` with no argument.
# MLXCTL_MODEL=qwen

# Server bind address and port. 0.0.0.0 is required for host.docker.internal.
# MLXCTL_HOST=0.0.0.0
# MLXCTL_PORT=8080

# Default reply cap when a request doesn't set its own max_tokens.
# MLXCTL_MAX_TOKENS=8192

# Memory guards (see README). Raise the bytes ceiling if you raise the macOS
# Metal wired limit; lower it if you still hit out-of-memory.
# MLXCTL_PROMPT_CACHE_BYTES=10G
# MLXCTL_PROMPT_CACHE_SIZE=4
# MLXCTL_DECODE_CONCURRENCY=8
# MLXCTL_PROMPT_CONCURRENCY=2

# Seconds to wait for a model to load before `serve` stops blocking.
# MLXCTL_HEALTH_TIMEOUT=300

# Where pid/info/log live (and the default models.json). Defaults to ~/.mlxctl.
# MLXCTL_STATE_DIR=~/.mlxctl

# Extra nicknames file (JSON object of nickname -> repo id), merged over the
# built-ins. Defaults to <state-dir>/models.json if present.
# MLXCTL_NICKNAMES_FILE=~/.mlxctl/models.json
